rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read menu items and settings
    match /menu/{item} {
      allow read: if true;
    }

    match /settings/{setting} {
      allow read: if true;
    }

    // Allow anyone to read tables (for QR code access)
    match /tables/{table} {
      allow read: if true;

      // Admins may fully manage tables.
      allow create, delete: if request.auth != null && request.auth.token.admin == true;

      // Customers may update table occupancy during checkout/order flow.
      allow update: if request.writeFields.hasOnly(['status', 'currentOrderId', 'updatedAt']) &&
                    request.resource.data.status in ['available', 'occupied', 'reserved'];
    }

    // Allow anyone to create and read orders (for customer ordering)
    match /orders/{order} {
      allow read: if true;
      allow create: if true;

      // Customers also need to update order status during checkout and kitchen flow.
      allow update: if true;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
  }
}